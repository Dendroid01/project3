            <FormField
                iconName="email"
                label="Email address"
                type="email"
                placeholder="your@email.com"
                error={errors.email?.message}
                {...register('email')}
            />

            <FormField
                iconName="lock"
                label="Password"
                type="password"
                placeholder="••••••••"
                error={errors.password?.message}
                {...register('password')}
            />

            <FormField
                iconName="lock_reset"
                label="Confirm password"
                type="password"
                placeholder="••••••••"
                error={errors.confirmPassword?.message}
