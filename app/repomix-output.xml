            />

            <FormField
                iconName="lock"
                iconClassName="lg:text-2xl"
                label="Пароль"
                type="password"
                placeholder="••••••••"
                error={errors.password?.message}
                link={{text: 'Забыли пароль?', href: '/forgot-password'}}
                {...register('password')}
